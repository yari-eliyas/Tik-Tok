{
    "name": "e-yari/tik-tok",
    "description": "Simple and lightweight tik() / tok() timer for Laravel",
    "keywords": ["laravel", "timer", "debug", "benchmark", "tik", "tok"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Eliyas Yari",
            "email": "yari.eliyas@email.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "EYari\\TikTok\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "EYari\\TikTok\\TikTokServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0"
    }
}